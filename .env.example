# FORE — environment variables (copy to .env.local for Next.js, set on Vercel/Render for deploys)
# Never commit real secrets. See docs/CONTRACTS.md CONTRACT-006 / CONTRACT-008.

# Base URL of the Python ML service on Render (server-side only, used by Next.js API routes).
# Local dev defaults to http://127.0.0.1:8000 if unset.
RENDER_ML_BASE_URL=http://127.0.0.1:8000

# Groq API key for the DECIDE route's tool-calling. If unset, the DECIDE route falls back to a
# deterministic path that STILL calls the real canIAfford function (numbers stay real).
GROQ_API_KEY=

# Optional: override the Groq model (defaults to llama-3.1-8b-instant).
GROQ_MODEL=llama-3.1-8b-instant

# ML service side (set on Render): comma-separated extra CORS origins (your Vercel domain),
# in addition to localhost. e.g. https://your-app.vercel.app
ALLOWED_ORIGINS=
