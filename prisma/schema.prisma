// FORE — PostgreSQL schema (FORE_Blueprint 2 §7)
// User-scoped financial sessions; refresh tokens stored server-side for revocation.
// Account/settings/billing models are additive — they do not alter ML/core finance logic.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String?   @map("password_hash")
  name              String?
  provider          String    @default("email") // email | google | microsoft
  providerAccountId String?   @map("provider_account_id")
  emailVerifiedAt   DateTime? @map("email_verified_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  refreshTokens    RefreshToken[]
  sessions         FinancialSession[]
  conversations    Conversation[]
  categoryRules    CategoryRule[]
  statementUploads StatementUpload[]
  consent          UserConsent?
  preferences      UserPreferences?
  authTokens       AuthToken[]
  subscription     Subscription?

  @@unique([provider, providerAccountId])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique @map("token_hash")
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  userAgent String?   @map("user_agent")
  ipHint    String?   @map("ip_hint")

  @@index([userId])
  @@map("refresh_tokens")
}

model AuthToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // email_verify | password_reset
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId, type])
  @@map("auth_tokens")
}

model UserPreferences {
  id              String   @id @default(cuid())
  userId          String   @unique @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  appearance      String   @default("light") // light | evening
  emailProduct    Boolean  @default(true) @map("email_product")
  emailSecurity   Boolean  @default(true) @map("email_security")
  emailMarketing  Boolean  @default(false) @map("email_marketing")
  inAppAlerts     Boolean  @default(true) @map("in_app_alerts")
  weeklyBrief     Boolean  @default(true) @map("weekly_brief")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("user_preferences")
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique @map("user_id")
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                 String    @default("free") // free | pro | business
  status               String    @default("active") // active | canceled | past_due | trialing
  currentPeriodEnd     DateTime? @map("current_period_end")
  cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")
  stripeCustomerId     String?   @map("stripe_customer_id")
  stripeSubscriptionId String?   @map("stripe_subscription_id")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  createdAt            DateTime  @default(now()) @map("created_at")

  @@map("subscriptions")
}

model FinancialSession {
  id                 String   @id @default(cuid())
  userId             String   @map("user_id")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  persona            String?
  monthlyIncome      Float    @map("monthly_income")
  incomeBracket      String   @map("income_bracket")
  cityTier           String   @map("city_tier")
  dataSource         String   @default("demo") @map("data_source") // demo | csv
  csvFileName        String?  @map("csv_file_name")
  archetypeLabel     String?  @map("archetype_label")
  archetypeDistances Json?    @map("archetype_distances")
  burnRate           Json?    @map("burn_rate")
  benchmark          Json?    @map("benchmark")
  goal               Json?    @map("goal")
  lastDecideVerdict  Json?    @map("last_decide_verdict")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  transactions     Transaction[]
  conversations    Conversation[]
  statementUploads StatementUpload[]

  @@index([userId, isActive])
  @@map("financial_sessions")
}

model Transaction {
  id             String           @id @default(cuid())
  sessionId      String           @map("session_id")
  session        FinancialSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  date           String
  category       String
  amount         Float
  descriptionEnc String?          @map("description_enc")
  merchant       String?
  confidence     Float?
  source         String? // parser | user | rule
  fingerprint    String?
  statementId    String?          @map("statement_id")
  statement      StatementUpload? @relation(fields: [statementId], references: [id], onDelete: SetNull)
  createdAt      DateTime         @default(now()) @map("created_at")

  @@index([sessionId, date])
  @@index([fingerprint])
  @@map("transactions")
}

model Conversation {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String           @map("session_id")
  session   FinancialSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  title     String?
  summary   String?          @db.Text
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  messages ConversationMessage[]

  @@index([userId, updatedAt])
  @@map("conversations")
}

model ConversationMessage {
  id             String       @id @default(cuid())
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // user | assistant | tool
  content        String       @db.Text
  toolName       String?      @map("tool_name")
  toolPayload    Json?        @map("tool_payload")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([conversationId, createdAt])
  @@map("conversation_messages")
}

model CategoryRule {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchType String   @map("match_type") // merchant | contains
  pattern   String
  category  String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("category_rules")
}

model StatementUpload {
  id         String           @id @default(cuid())
  sessionId  String           @map("session_id")
  session    FinancialSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId     String           @map("user_id")
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName   String           @map("file_name")
  uploadedAt DateTime         @default(now()) @map("uploaded_at")
  rowCount   Int              @map("row_count")

  transactions Transaction[]

  @@index([userId, uploadedAt])
  @@map("statement_uploads")
}

model UserConsent {
  id                String    @id @default(cuid())
  userId            String    @unique @map("user_id")
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  csvUploadAt       DateTime? @map("csv_upload_at")
  aiProcessingAt    DateTime? @map("ai_processing_at")
  benchmarkOptInAt  DateTime? @map("benchmark_opt_in_at")
  privacyAcceptedAt DateTime? @map("privacy_accepted_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@map("user_consents")
}

model BenchmarkAggregate {
  id            String   @id @default(cuid())
  incomeBracket String   @map("income_bracket")
  cityTier      String   @map("city_tier")
  category      String
  p25           Float
  p50           Float
  p75           Float
  p90           Float
  sampleCount   Int      @map("sample_count")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([incomeBracket, cityTier, category])
  @@map("benchmark_aggregates")
}
